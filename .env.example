ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://kip:replace-with-url-safe-password@postgres:5432/kip
POSTGRES_DB=kip
POSTGRES_USER=kip
POSTGRES_PASSWORD=replace-with-url-safe-password
KIP_POSTGRES_PORT=5433
KIP_BACKEND_PORT=8000
KIP_FRONTEND_PORT=5001
KIP_PUBLIC_API_URL=http://localhost:8000
KIP_SEED_DEMO=1
KIP_ADMIN_EMAIL=admin@example.com
KIP_ADMIN_USERNAME=admin
KIP_ADMIN_PASSWORD=replace-with-local-admin-password
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,http://localhost:5000,http://127.0.0.1:5000
KIP_API_BASE_URL=http://127.0.0.1:8000
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
CSV_IMPORT_MAX_BYTES=5242880
